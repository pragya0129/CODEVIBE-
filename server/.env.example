# Server Port
PORT=5002

# MongoDB connection string (DB_URL takes precedence over MONGODB_URI)
DB_URL=mongodb://127.0.0.1:27017/codevibe
# MONGODB_URI=mongodb://localhost:27017/codevibe

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://codevibeforyou.netlify.app

# Contributor leaderboard API endpoint (used by GitHub Actions sync)
LEADERBOARD_API_URL=https://codevibe-3.onrender.com/api/contributors/sync

# Secret token for authenticating leaderboard API requests
LEADERBOARD_API_TOKEN=
